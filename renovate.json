{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "platformAutomerge": false,
  "enabledManagers": [
    "github-actions",
    "terraform"
  ],
  "terraform": {
    "fileMatch": [
      "^/terraform/.*\\.tf$"
    ]
  },
  "prHourlyLimit": 20,
  "labels": ["dependencies", "renovate"]
}